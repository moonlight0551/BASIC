1 REM FIBONACCI NUMBERS -- ORIGINAL PRG FOR APPLE-1 INTEGER BASIC
2 REM AUTHOR: UNKNOWN -- ADAPTED FOR MBASIC BY P-LAB 2020
3 TESTED ON A RC2014 RUNNING MBASIC UNDER CP/M
4 INPUT "Enter the number of digits ?",N
5 WIDTH 255
30 DIM A(N)
40 DIM B(N)
50 DIM C(N)
60 K=0:X#=1
70 FOR I=1 TO N
80 A(I)=0:B(I)=0:C(I)=0
90 NEXT I
100 B(N)=1
110 print " 0 --> 0":print " 1 --> 1"
210 REM main loop
220 X#=X#+1
230 PRINT X#;"--> ";
240 FOR J=N TO 1 STEP -1
250 Z=A(J)+B(J)+K
260 K=0:Y=INT(Z/10)
270 IF Y>0 THEN 500
290 C(J)=Z
300 NEXT J
310 FOR L=1 TO N
320 A(L)=B(L)
330 NEXT L
340 FOR L=1 TO N
350 B(L)=C(L)
360 NEXT L
365 W=0
370 FOR L=1 TO N
380 IF (W=0 AND C(L)=0) THEN 390
385 W=1: PRINT USING "#";C(L);
387 IF C(1)>0 THEN 1000
390 NEXT L
400 PRINT
410 GOTO 220
500 K=Y
510 Z=Z-(10*Y)
520 GOTO 290
1000 PRINT
1005 PRINT "Calculation completed."
1010 PRINT "Iterations=";X#
1020 PRINT "Number=";
1030 FOR L=1 TO N
1040 IF (W=0 AND C(L)=0) THEN 1060
1050 W=1: PRINT USING "#";C(L);
1060 NEXT L
1070 PRINT:PRINT
1080 END
