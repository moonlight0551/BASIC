10 DIM A(22,22),B(22,22)
15 REM A()=CURRENT GENERATION, B()=NEXT GENERATION

20 INPUT "ENTER INITIAL NUMBER OF ITERATIONS";L
25 REM NUMBER OF GENERATIONS TO CALCULATE

30 PRINT "ENTER INITIAL COORDINATES; 0,0 TO END"

40 REM ENTER INITIAL LIVE CELLS

50 INPUT X,Y

60 IF X+Y=0 THEN GOTO 120
65 REM 0,0 TERMINATES INPUT

70 IF (X<1) OR (X>20) OR (Y<1) OR (Y>20) THEN PRINT "ERROR RE-ENTER" : GOTO 50
75 REM VALID PLAYING AREA IS 1 TO 20

80 X=X+1 : Y=Y+1
85 REM SHIFT INTO 22X22 ARRAY WITH DEAD BORDER

90 A(X,Y)=A(X,Y)+10
95 REM MARK CELL AS ALIVE

100 FOR XW=X-1 TO X+1 : FOR YW=Y-1 TO Y+1 : A(XW,YW)=A(XW,YW)+1 : NEXT YW : NEXT XW
105 REM UPDATE NEIGHBOUR COUNTS

110 GOTO 50

120 REM INITIALIZATION COMPLETE

130 L$="+----------------------+"
135 REM TOP AND BOTTOM BORDER

140 INPUT "ENTER PAPER SIZE (IN LINES/PAGE), SET UP PAPER & HIT ENTER";P

150 FOR I=1 TO L STEP 2
155 REM TWO GENERATIONS ARE PRODUCED PER LOOP

160 REM DISPLAY CURRENT GENERATION

170 PRINT L$

180 FOR Y=1 TO 22 : PRINT "!"; : FOR X=1 TO 22

190 IF A(X,Y)<10 THEN PRINT " "; ELSE PRINT "*";

200 B(X,Y)=0
205 REM CLEAR NEXT GENERATION ARRAY

210 NEXT X : PRINT "!" : NEXT Y

220 PRINT L$

230 FOR J=25 TO P : PRINT : NEXT J
235 REM ADVANCE TO NEXT PAGE

240 REM BUILD NEXT GENERATION IN B()

250 FOR X=2 TO 21 : FOR Y=2 TO 21

260 AW=A(X,Y)

270 IF (AW<>3) AND (AW<>13) AND (AW<>14) THEN GOTO 310
275 REM LIFE RULES:
276 REM 3=DEAD WITH 3 NEIGHBOURS (BIRTH)
277 REM 13=ALIVE WITH 3 NEIGHBOURS (SURVIVES)
278 REM 14=ALIVE WITH 4 NEIGHBOURS (SURVIVES)

280 B(X,Y)=B(X,Y)+10

290 FOR XW=X-1 TO X+1 : FOR YW=Y-1 TO Y+1 : B(XW,YW)=B(XW,YW)+1 : NEXT YW : NEXT XW
295 REM UPDATE COUNTS FOR NEXT GENERATION

310 NEXT Y : NEXT X

320 REM DISPLAY NEW GENERATION

330 PRINT L$

340 FOR Y=1 TO 22 : PRINT "!"; : FOR X=1 TO 22

350 IF B(X,Y)<10 THEN PRINT " "; ELSE PRINT "*";

360 A(X,Y)=0
365 REM CLEAR CURRENT GENERATION ARRAY

370 NEXT X : PRINT "!" : NEXT Y

380 PRINT L$

390 FOR J=25 TO P : PRINT : NEXT J

400 REM BUILD FOLLOWING GENERATION IN A()

410 FOR X=2 TO 21 : FOR Y=2 TO 21

420 BW=B(X,Y)

430 IF (BW<>3) AND (BW<>13) AND (BW<>14) THEN GOTO 470

440 A(X,Y)=A(X,Y)+10

450 FOR XW=X-1 TO X+1 : FOR YW=Y-1 TO Y+1 : A(XW,YW)=A(XW,YW)+1 : NEXT YW : NEXT XW

470 NEXT Y : NEXT X

480 NEXT I

490 REM ASK FOR MORE ITERATIONS

500 INPUT "ENTER NUMBER OF ADDITIONAL ITERATIONS";L

510 IF L>0 THEN GOTO 130 ELSE END
