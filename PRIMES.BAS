10 REM PRIMES UP TO 1000 in MBASIC
12 REM THIS WORKS FINE ON CPM 2.2 USING THE SC126
20 PRINT "Prime numbers up to 1000:"
30 FOR N = 2 TO 1000
40   PRIME = -1
50   FOR D = 2 TO INT(SQR(N))
60     IF N / D = INT(N / D) THEN PRIME = 0
70   NEXT D
80   IF PRIME THEN PRINT N;
90 NEXT N
100 PRINT
110 END
