10 REM ************************************
20 REM * SIERPINSKI TRIANGLE V1.0         *
30 REM * FOR MICROSOFT MBASIC / CP-M      *
40 REM ************************************

50 DIM P(24,80)

60 REM CLEAR FRAME BUFFER

70 FOR Y=1 TO 24
80 FOR X=1 TO 80
90 P(Y,X)=0
100 NEXT X
110 NEXT Y

120 REM STARTING POINT

130 X=40
140 Y=12

150 REM TRIANGLE VERTICES

160 X1=40
170 Y1=1

180 X2=1
190 Y2=24

200 X3=80
210 Y3=24

220 REM MAIN LOOP

230 FOR I=1 TO 20000

240 R=INT(RND(1)*3)+1

250 IF R=1 THEN GOTO 300
260 IF R=2 THEN GOTO 340

270 VX=X3
280 VY=Y3
290 GOTO 370

300 VX=X1
310 VY=Y1
320 GOTO 370

340 VX=X2
350 VY=Y2

370 X=INT((X+VX)/2)
380 Y=INT((Y+VY)/2)

390 P(Y,X)=1

400 NEXT I

410 REM DISPLAY IMAGE

420 FOR Y=1 TO 24

430 FOR X=1 TO 80

440 IF P(Y,X)=0 THEN PRINT " ";
450 IF P(Y,X)=1 THEN PRINT "*";

460 NEXT X

470 PRINT

480 NEXT Y

490 END