10 REM ****************************************
20 REM * CP/M FRACTAL COLLECTION             *
30 REM * PROGRAM : 1DLIFE.BAS               *
40 REM * VERSION : 1.0                      *
50 REM * STATUS  : RELEASED                 *
60 REM * DATE    : 18-JUL-2026              *
70 REM ****************************************
80 REM
90 REM VERSION HISTORY
100 REM V1.0 Initial Release
110 REM Based on 1D Life by Usagi Electric
120 REM Added title screen
130 REM Added generation selection
140 REM Added density selection
150 REM ****************************************

160 LET M=69

170 PRINT
180 PRINT "***************************************"
190 PRINT "*     CP/M FRACTAL COLLECTION         *"
200 PRINT "***************************************"
210 PRINT
220 PRINT "PROGRAM 4 - 1D LIFE"
230 PRINT

240 INPUT "NUMBER OF GENERATIONS (25-500) ";GEN
250 IF GEN<25 THEN GEN=25
260 IF GEN>500 THEN GEN=500

270 INPUT "INITIAL DENSITY (1-9) ";DEN
280 IF DEN<1 THEN DEN=1
290 IF DEN>9 THEN DEN=9

300 PRINT
310 PRINT "Generating 1D Life..."
320 PRINT

330 REM INITIALISE CURRENT GENERATION ARRAY
340 DIM X(M)

350 REM INITIALISE NEXT GENERATION ARRAY
360 DIM Y(M)

370 REM GENERATE RANDOM STARTING POPULATION

380 FOR I=0 TO M

390 LET R=RND(1)*10

400 IF R>DEN THEN 430

410 LET X(I)=1
420 GOTO 440

430 LET X(I)=0

440 NEXT I

450 REM DISPLAY INITIAL GENERATION

460 FOR I=2 TO M-2

470 IF X(I)=1 THEN 500

480 PRINT " ";
490 GOTO 510

500 PRINT "*";

510 NEXT I

520 PRINT

530 REM MAIN GENERATION LOOP

540 FOR T=1 TO GEN

550 FOR I=2 TO M-2
560 GOTO 830
570 NEXT I

580 REM COPY NEW GENERATION

590 FOR I=0 TO M

600 LET X(I)=Y(I)

610 IF X(I)=0 THEN 640

620 PRINT "*";
630 GOTO 650

640 PRINT " ";

650 NEXT I

660 PRINT

670 NEXT T

680 PRINT
690 PRINT "Completed."
700 END

820 REM --------------------------------------
830 REM COUNT NEIGHBOURS
840 REM --------------------------------------

850 LET C=0

860 FOR Z=I-2 TO I+2

870 IF Z=I THEN 900
880 IF X(Z)=0 THEN 900

890 LET C=C+1

900 NEXT Z

910 IF X(I)=0 THEN 1010

920 REM CELL IS ALIVE

930 LET Y(I)=0

940 IF C=2 THEN 980
950 IF C=4 THEN 980

960 GOTO 570

980 LET Y(I)=1
990 GOTO 570

1000 REM CELL IS DEAD

1010 LET Y(I)=0

1020 IF C=2 THEN 1060
1030 IF C=3 THEN 1060

1040 GOTO 570

1060 LET Y(I)=1
1070 GOTO 570